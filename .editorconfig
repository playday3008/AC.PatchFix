root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cpp,hpp,h}]
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.{cmake,txt}]
indent_style = space
indent_size = 4

[*.ini]
indent_style = space
indent_size = 0

[*.md]
trim_trailing_whitespace = false
